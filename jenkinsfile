pipeline {
    agent any

    tools {
        jdk 'jdk21'
        nodejs 'node18'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        JAVA_HOME = '/usr/lib/jvm/temurin-21-jdk-amd64'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"
        IMAGE_NAME = "teja1111/swiggy:latest"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'master',
                url: 'https://github.com/tejaswaroop66/DevOps-Project-Swiggy'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh """
                    ${SCANNER_HOME}/bin/sonar-scanner \
                    -Dsonar.projectName=Swiggy \
                    -Dsonar.projectKey=Swiggy
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: false
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('OWASP Dependency Scan') {
            steps {
                dependencyCheck odcInstallation: 'DC',
                additionalArguments: '--scan . --disableYarnAudit --disableNodeAudit'

                dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            }
        }

        stage('Trivy File System Scan') {
            steps {
                sh 'trivy fs . > trivyfs-report.txt'
            }
        }

        stage('Docker Build Image') {
            steps {
                sh 'docker build -t swiggy .'
            }
        }

        stage('Docker Tag Image') {
            steps {
                sh 'docker tag swiggy ${IMAGE_NAME}'
            }
        }

        stage('Docker Push Image') {
            steps {
                withDockerRegistry(credentialsId: 'docker', toolName: 'docker') {
                    sh 'docker push ${IMAGE_NAME}'
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh 'trivy image ${IMAGE_NAME} > trivyimage-report.txt'
            }
        }

        stage('Deploy Container') {
            steps {
                sh 'docker rm -f swiggy || true'
                sh 'docker run -d --name swiggy -p 3000:3000 ${IMAGE_NAME}'
            }
        }
    }
}
